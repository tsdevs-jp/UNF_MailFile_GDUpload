$file = "C:\Development\UNF_MailFile_GDUpload\UNF_MailFile_GDUpload.csproj"
$content = [System.IO.File]::ReadAllText($file, [System.Text.Encoding]::UTF8)

$insertBefore = '  <!-- This section defines VSTO properties'

$newTarget = @'
  <!--
    Release ビルド後に Inno Setup インストーラーを自動コンパイルする。
    インストール先: Setup\output\UNF_MailFile_GDUpload_Setup_*.exe
    Inno Setup が見つからない場合はビルド警告のみで中断しない。
  -->
  <Target Name="CompileInnoSetupInstaller" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <IsccExe Condition="Exists('$(ProgramFiles)\Inno Setup 6\ISCC.exe')">$(ProgramFiles)\Inno Setup 6\ISCC.exe</IsccExe>
      <IsccExe Condition="'$(IsccExe)' == '' AND Exists('$(ProgramFiles(x86))\Inno Setup 6\ISCC.exe')">$(ProgramFiles(x86))\Inno Setup 6\ISCC.exe</IsccExe>
      <IsccExe Condition="'$(IsccExe)' == '' AND Exists('$(LOCALAPPDATA)\Programs\Inno Setup 6\ISCC.exe')">$(LOCALAPPDATA)\Programs\Inno Setup 6\ISCC.exe</IsccExe>
    </PropertyGroup>
    <Warning Text="Inno Setup 6 が見つかりません。Setup\output\ のインストーラーは更新されませんでした。https://jrsoftware.org/isdl.php からインストールしてください。" Condition="'$(IsccExe)' == ''" />
    <Message Text="Inno Setup インストーラーをコンパイル中: $(MSBuildProjectDirectory)\Setup\setup.iss" Importance="high" Condition="'$(IsccExe)' != ''" />
    <Exec Command="&quot;$(IsccExe)&quot; &quot;$(MSBuildProjectDirectory)\Setup\setup.iss&quot;" Condition="'$(IsccExe)' != ''" />
  </Target>

'@

if ($content.Contains('CompileInnoSetupInstaller')) {
    Write-Host "INFO: target already exists, skipping"
    exit 0
}

$newContent = $content.Replace($insertBefore, $newTarget + $insertBefore)

if ($newContent -eq $content) {
    Write-Host "ERROR: insertion point not found"
    exit 1
}

[System.IO.File]::WriteAllText($file, $newContent, [System.Text.Encoding]::UTF8)
Write-Host "OK: CompileInnoSetupInstaller target inserted"
