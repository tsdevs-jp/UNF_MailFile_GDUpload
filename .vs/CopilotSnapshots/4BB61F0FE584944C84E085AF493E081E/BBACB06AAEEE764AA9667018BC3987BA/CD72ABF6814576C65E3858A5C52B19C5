; ================================================================
; UNF MailFile GD Upload — Inno Setup 6 インストーラスクリプト
;
; 【ビルド手順】
;   1. Visual Studio で Release ビルドを実行
;   2. Inno Setup 6.x をインストール
;      https://jrsoftware.org/isdl.php
;   3. このファイルを Inno Setup Compiler で開いて F9 (Compile)
;   4. Setup\output\ にインストーラ EXE が生成される
;
; 【配布先パス】
;   C:\Program Files\Unfake\UNF_MailFile_GDUpload\
; ================================================================

#define AppName      "UNF MailFile GD Upload"
#define AppVersion   "1.0.0"
#define AppPublisher "Unfake Co.,Ltd."
#define AddinProgId  "UNF_MailFile_GDUpload"
; 署名証明書のサムプリント（UNF_MailFile_GDUpload_TemporaryKey.pfx 由来）
#define CertThumbprint "0D8063059CFF2B7693BF3DFF07BC23190C2F1464"

[Setup]
; GUID は Properties\AssemblyInfo.cs の Guid 属性と同一値を使用
AppId={{92E3EED4-DD38-424D-AFDC-81C3AB2B4C21}
AppName={#AppName}
AppVersion={#AppVersion}
AppVerName={#AppName} {#AppVersion}
AppPublisher={#AppPublisher}

; インストール先: C:\Program Files\Unfake\UNF_MailFile_GDUpload\
DefaultDirName={autopf}\Unfake\UNF_MailFile_GDUpload
DisableDirPage=no
DisableProgramGroupPage=yes

; 出力先・ファイル名
OutputDir=output
OutputBaseFilename=UNF_MailFile_GDUpload_Setup_{#AppVersion}

; 圧縮
Compression=lzma2/ultra64
SolidCompression=yes

; UI スタイル
WizardStyle=modern

; 管理者権限が必要（Program Files への書き込みのため）
; ※ HKCU への登録はインストーラーを実行したユーザーのプロファイルに適用される
;    Outlook を使用する各ユーザーがインストーラーを実行するか、
;    管理者が代表で実行してください
PrivilegesRequired=admin
UsedUserAreasWarning=no

; 64 ビット Windows では 64 ビットモードでインストール
; → {autopf} = C:\Program Files（x86 ではなく）
ArchitecturesInstallIn64BitMode=x64compatible

; Windows 7 SP1 以上を要求
MinVersion=6.1sp1

; アンインストール表示
UninstallDisplayName={#AppName}

[Languages]
Name: "japanese"; MessagesFile: "compiler:Languages\Japanese.isl"

[CustomMessages]
japanese.PrerequisiteDotNet=.NET Framework 4.8 以降がインストールされていません。%n%n下記 URL からインストールしてから再実行してください。%n%nhttps://dotnet.microsoft.com/download/dotnet-framework/net48
japanese.PrerequisiteVsto=Visual Studio 2010 Tools for Office Runtime がインストールされていません。%n%n下記 URL からインストールしてから再実行してください。%n%nhttps://www.microsoft.com/download/details.aspx?id=56961
japanese.FinishedLabel=Outlook を再起動すると「{#AppName}」アドインが有効になります。

[Files]
; Release ビルドのファイルをコピー（.pdb デバッグシンボルを除く）
; ※ recursesubdirs を使わないことで app.publish サブフォルダを自動除外
Source: "..\bin\Release\*"; DestDir: "{app}"; \
    Flags: ignoreversion; \
    Excludes: "*.pdb"

; アドイン署名証明書（インストール中に一時使用し自動削除）
Source: "UNF_MailFile_GDUpload.cer"; DestDir: "{tmp}"; \
    Flags: deleteafterinstall

[Registry]
; ================================================================
; HKCU — 現在のユーザーへ登録
;         HKCU は 32/64 ビット Outlook いずれでも有効（WOW64 非依存）
;         VSTO アドインの標準的な登録先
; ================================================================
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Description";  ValueData: "Outlook アドオン — 添付ファイルを Google Drive へ自動アップロードし、本文に共有リンクを挿入します。"; Flags: uninsdeletekey
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "FriendlyName"; ValueData: "{#AppName}"
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: dword;  ValueName: "LoadBehavior"; ValueData: 3
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Manifest";     ValueData: "{code:GetManifestPath}"

[Run]
; ----------------------------------------------------------------
; アドイン署名証明書を Trusted Publishers ストアへインポート
; （インポートしないと VSTO が証明書を信頼できずアドインが起動しない）
; ----------------------------------------------------------------
Filename: "certutil.exe"; \
    Parameters: "-f -addstore TrustedPublisher ""{tmp}\UNF_MailFile_GDUpload.cer"""; \
    Flags: runhidden; \
    StatusMsg: "証明書を Trusted Publishers ストアに登録中..."

Filename: "certutil.exe"; \
    Parameters: "-f -addstore Root ""{tmp}\UNF_MailFile_GDUpload.cer"""; \
    Flags: runhidden; \
    StatusMsg: "証明書をルート CA ストアに登録中..."

[UninstallRun]
; アンインストール時に証明書をストアから削除
Filename: "certutil.exe"; \
    Parameters: "-delstore TrustedPublisher {#CertThumbprint}"; \
    Flags: runhidden; \
    RunOnceId: "RemoveCertTrustedPublisher"

Filename: "certutil.exe"; \
    Parameters: "-delstore Root {#CertThumbprint}"; \
    Flags: runhidden; \
    RunOnceId: "RemoveCertRoot"

[Code]

{ ----------------------------------------------------------------
  VSTO マニフェストパスの生成
  インストール先パスの \ を / に変換して file:// URL 形式にする

  例:
    インストール先: C:\Program Files\Unfake\UNF_MailFile_GDUpload
    生成値: file:///C:/Program Files/Unfake/UNF_MailFile_GDUpload/UNF_MailFile_GDUpload.vsto|vstolocal
  ---------------------------------------------------------------- }
function GetManifestPath(Param: string): string;
var
  Dir: string;
begin
  Dir := ExpandConstant('{app}');
  StringChangeEx(Dir, '\', '/', True);
  Result := 'file:///' + Dir + '/{#AddinProgId}.vsto|vstolocal';
end;

{ ----------------------------------------------------------------
  .NET Framework 4.8 インストール確認
  Release レジストリ値 528040 以上 = .NET Framework 4.8
  ---------------------------------------------------------------- }
function IsDotNet48Installed: Boolean;
var
  Release: Cardinal;
begin
  Result := RegQueryDWordValue(
    HKLM,
    'SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full',
    'Release',
    Release)
    and (Release >= 528040);
end;

{ ----------------------------------------------------------------
  Visual Studio 2010 Tools for Office Runtime (VSTO 4.0) 確認
  VSTOR の Installed 値 = 1 で確認
  64 ビット OS では WOW64 ノードも確認する
  ---------------------------------------------------------------- }
function IsVstoRuntimeInstalled: Boolean;
var
  Installed: Cardinal;
begin
  Result := RegQueryDWordValue(
    HKLM,
    'SOFTWARE\Microsoft\VSTO Runtime Setup\v4R',
    'Installed',
    Installed)
    and (Installed = 1);

  if not Result then
    Result := RegQueryDWordValue(
      HKLM,
      'SOFTWARE\WOW6432Node\Microsoft\VSTO Runtime Setup\v4R',
      'Installed',
      Installed)
      and (Installed = 1);

  if not Result then
    Result := RegQueryDWordValue(
      HKLM,
      'SOFTWARE\Microsoft\VSTO Runtime Setup\v4',
      'Installed',
      Installed)
      and (Installed = 1);
end;

{ ----------------------------------------------------------------
  インストール開始前の前提条件チェック
  ---------------------------------------------------------------- }
function InitializeSetup: Boolean;
begin
  Result := True;

  if not IsDotNet48Installed then
  begin
    MsgBox(CustomMessage('PrerequisiteDotNet'), mbCriticalError, MB_OK);
    Result := False;
    Exit;
  end;

  if not IsVstoRuntimeInstalled then
  begin
    MsgBox(CustomMessage('PrerequisiteVsto'), mbCriticalError, MB_OK);
    Result := False;
    Exit;
  end;
end;

{ ----------------------------------------------------------------
  アンインストール完了後：Unfake 親ディレクトリが空なら削除
  ---------------------------------------------------------------- }
procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);
var
  UnfakeDir: string;
begin
  if CurUninstallStep = usPostUninstall then
  begin
    UnfakeDir := ExtractFileDir(ExpandConstant('{app}'));
    if DirExists(UnfakeDir) then
      RemoveDir(UnfakeDir);  // 空でなければ何もしない（安全）
  end;
end;
