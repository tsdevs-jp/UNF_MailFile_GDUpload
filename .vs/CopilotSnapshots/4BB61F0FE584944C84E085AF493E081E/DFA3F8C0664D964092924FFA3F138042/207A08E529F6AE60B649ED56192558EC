        private const string SkipProcessingUserPropertyName = "UNF_GDUpload_SkipProcessing";
        private const string ProcessingUserPropertyName = "UNF_GDUpload_Processing";
        private const string AttachmentHiddenPropertyTag = "http://schemas.microsoft.com/mapi/proptag/0x7FFE000B";
