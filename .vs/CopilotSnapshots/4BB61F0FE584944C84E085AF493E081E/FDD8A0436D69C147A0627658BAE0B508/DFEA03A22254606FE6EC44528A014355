; ================================================================
; UNF MailFile GD Upload — Inno Setup 6 インストーラスクリプト
;
; 【ビルド手順】
;   1. Visual Studio で Release ビルドを実行
;   2. Inno Setup 6.x をインストール
;      https://jrsoftware.org/isdl.php
;   3. このファイルを Inno Setup Compiler で開いて F9 (Compile)
;   4. Setup\output\ にインストーラ EXE が生成される
; ================================================================

#define AppName      "UNF MailFile GD Upload"
#define AppVersion   "1.0.0"
#define AppPublisher "Unfake Co.,Ltd."
#define AddinProgId  "UNF_MailFile_GDUpload"

[Setup]
; GUID は Properties\AssemblyInfo.cs の Guid 属性と同一値を使用
AppId={{92E3EED4-DD38-424D-AFDC-81C3AB2B4C21}
AppName={#AppName}
AppVersion={#AppVersion}
AppVerName={#AppName} {#AppVersion}
AppPublisher={#AppPublisher}

; インストール先: C:\Program Files\Unfake\UNF_MailFile_GDUpload\
DefaultDirName={autopf}\Unfake\UNF_MailFile_GDUpload
DisableDirPage=no
DisableProgramGroupPage=yes

; 出力先・ファイル名
OutputDir=output
OutputBaseFilename=UNF_MailFile_GDUpload_Setup_{#AppVersion}

; 圧縮
Compression=lzma2/ultra64
SolidCompression=yes

; UI スタイル
WizardStyle=modern
WizardResizable=no

; 管理者権限が必要（Program Files への書き込みのため）
PrivilegesRequired=admin

; 64 ビット Windows では 64 ビットモードでインストール
; → {autopf} = C:\Program Files（x86 ではなく）
ArchitecturesInstallIn64BitMode=x64

; Windows 7 以上を要求
MinVersion=6.1

; アンインストール表示
UninstallDisplayName={#AppName}

[Languages]
Name: "japanese"; MessagesFile: "compiler:Languages\Japanese.isl"

[CustomMessages]
japanese.PrerequisiteMissing=.NET Framework 4.8 以降がインストールされていません。%n%n下記 URL からインストールしてから再実行してください。%n%nhttps://dotnet.microsoft.com/download/dotnet-framework/net48
japanese.FinishedLabel=Outlook を再起動すると「{#AppName}」アドインが有効になります。

[Files]
; Release ビルドの全ファイルをコピー（.pdb デバッグシンボルを除く）
Source: "..\bin\Release\*"; DestDir: "{app}"; \
    Flags: ignoreversion recursesubdirs createallsubdirs; \
    Excludes: "*.pdb"

[Registry]
; ================================================================
; HKCU — 現在のユーザーへ登録
;         32/64 ビット Outlook いずれでも有効（WOW64 非依存）
; ================================================================
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Description";  ValueData: "Outlook アドオン — 添付ファイルを Google Drive へ自動アップロードし、本文に共有リンクを挿入します。"; Flags: uninsdeletekey
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "FriendlyName"; ValueData: "{#AppName}"
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: dword;  ValueName: "LoadBehavior"; ValueData: 3
Root: HKCU; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Manifest";     ValueData: "{code:GetManifestPath}"

; ================================================================
; HKLM 32-bit — 32 ビット Outlook (64 ビット Windows) 向け
;               実際の書き込み先: HKLM\SOFTWARE\WOW6432Node\...
; ================================================================
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Description";  ValueData: "Outlook アドオン — 添付ファイルを Google Drive へ自動アップロードし、本文に共有リンクを挿入します。"; Flags: uninsdeletekey bit32
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "FriendlyName"; ValueData: "{#AppName}";  Flags: bit32
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: dword;  ValueName: "LoadBehavior"; ValueData: 3;              Flags: bit32
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Manifest";     ValueData: "{code:GetManifestPath}"; Flags: bit32

; ================================================================
; HKLM 64-bit — 64 ビット Outlook 向け（64 ビット OS のみ）
; ================================================================
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Description";  ValueData: "Outlook アドオン — 添付ファイルを Google Drive へ自動アップロードし、本文に共有リンクを挿入します。"; Flags: uninsdeletekey bit64; Check: Is64BitInstallMode
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "FriendlyName"; ValueData: "{#AppName}";  Flags: bit64; Check: Is64BitInstallMode
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: dword;  ValueName: "LoadBehavior"; ValueData: 3;              Flags: bit64; Check: Is64BitInstallMode
Root: HKLM; Subkey: "Software\Microsoft\Office\Outlook\Addins\{#AddinProgId}"; ValueType: string; ValueName: "Manifest";     ValueData: "{code:GetManifestPath}"; Flags: bit64; Check: Is64BitInstallMode

[Code]

{ ----------------------------------------------------------------
  VSTO マニフェストパスの生成
  インストール先パスの \ を / に変換して file:// URL 形式にする

  例:
    インストール先: C:\Program Files\Unfake\UNF_MailFile_GDUpload
    生成値: file:///C:/Program Files/Unfake/UNF_MailFile_GDUpload/UNF_MailFile_GDUpload.vsto|vstolocal
  ---------------------------------------------------------------- }
function GetManifestPath(Param: string): string;
var
  Dir: string;
begin
  Dir := ExpandConstant('{app}');
  StringChangeEx(Dir, '\', '/', True);
  Result := 'file:///' + Dir + '/{#AddinProgId}.vsto|vstolocal';
end;

{ ----------------------------------------------------------------
  .NET Framework 4.8 インストール確認
  Release レジストリ値 528040 以上 = .NET Framework 4.8
  ---------------------------------------------------------------- }
function IsDotNet48Installed: Boolean;
var
  Release: Cardinal;
begin
  Result := RegQueryDWordValue(
    HKLM,
    'SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full',
    'Release',
    Release)
    and (Release >= 528040);
end;

{ ----------------------------------------------------------------
  インストール開始前の前提条件チェック
  ---------------------------------------------------------------- }
function InitializeSetup: Boolean;
begin
  Result := True;

  if not IsDotNet48Installed then
  begin
    MsgBox(CustomMessage('PrerequisiteMissing'), mbCriticalError, MB_OK);
    Result := False;
  end;
end;

{ ----------------------------------------------------------------
  アンインストール完了後：Unfake 親ディレクトリが空なら削除
  ---------------------------------------------------------------- }
procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);
var
  UnfakeDir: string;
begin
  if CurUninstallStep = usPostUninstall then
  begin
    UnfakeDir := ExtractFileDir(ExpandConstant('{app}'));
    if DirExists(UnfakeDir) then
      RemoveDir(UnfakeDir);  // 空でなければ何もしない（安全）
  end;
end;
